# Google Gemini API Key
# Get yours at https://aistudio.google.com/apikey
# NOTE: EXPO_PUBLIC_* keys are bundled client-side. For production, consider
# proxying through a backend. Acceptable for MVP as these are rate-limited API keys.
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Discogs API Credentials
# Get yours at https://www.discogs.com/settings/developers
EXPO_PUBLIC_DISCOGS_KEY=your_discogs_key_here
EXPO_PUBLIC_DISCOGS_SECRET=your_discogs_secret_here

# RevenueCat API Keys
# Get yours at https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your_revenuecat_android_key_here
